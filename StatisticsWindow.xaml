<Window x:Class="Hangman.View.StatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Hangman.View"
        mc:Ignorable="d"
        Title="StatisticsWindow" Height="450" Width="800">
    <Grid Margin="10">
        <DataGrid ItemsSource="{Binding AllMatches}" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Player" Binding="{Binding PlayerName}" Width="*"/>
                <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=\{0:dd/MM/yyyy HH:mm\}}" Width="*"/>
                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="*"/>
                <DataGridTextColumn Header="Result" Binding="{Binding Result}" Width="*"/>
                <DataGridTextColumn Header="Level" Binding="{Binding LevelReached}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
